# Todoist OAuth credentials (get from https://developer.todoist.com/appconsole.html)
CLIENT_ID="your-client-id-here"
CLIENT_SECRET="your-client-secret-here"

# OAuth security
STATE_SECRET="random-string-for-csrf-protection"

# Cookie encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="your-64-character-hex-string-here"
COOKIE_SECRET="random-string-for-cookie-signing"

# OAuth redirect URI
# PRODUCTION: https://nba-todoist-import.vercel.app/api/auth/callback
# LOCAL: http://localhost:3000/api/auth/callback
# NOTE: Update this in your Todoist app settings: https://developer.todoist.com/appconsole.html
REDIRECT_URI="http://localhost:3000/api/auth/callback"
